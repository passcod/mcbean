@schema {id crate:tracey-config@1, cli tracey}

specs (
    {
        name editor
        source_url https://github.com/passcod/mcbean
        include (docs/spec/editor.md)
        impls (
            {
                name main
                include (
                    src/*.rs
                    src/**/*.rs
                )
            }
        )
    }
)
